	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const apiKey = pm.collectionVariables.get('api_key');",
					"const apiSecret = pm.collectionVariables.get('api_secret');",
					"const signRequests = pm.collectionVariables.get('sign_requests') === 'true';",
					"",
					"pm.request.headers.upsert({ key: 'Authorization', value: `token ${apiKey}:${apiSecret}` });",
					"pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
					"pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
					"",
					"let requestId = pm.collectionVariables.get('request_id');",
					"if (!requestId) {",
					"    requestId = pm.variables.replaceIn('{{$guid}}');",
					"}",
					"pm.request.headers.upsert({ key: 'X-Request-ID', value: requestId });",
					"",
					"if (signRequests && apiSecret && apiSecret !== 'YOUR_API_SECRET') {",
					"    const timestamp = Math.floor(Date.now() / 1000).toString();",
					"    const body = (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) ? pm.request.body.raw : '';",
					"    const message = `${timestamp}.${body}`;",
					"    const signature = CryptoJS.HmacSHA256(message, apiSecret).toString(CryptoJS.enc.Hex);",
					"    pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
					"    pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "Sales Invoices",
			"item": [
				{
					"name": "sync_sales_invoices — Create & Submit",
					"request": {
