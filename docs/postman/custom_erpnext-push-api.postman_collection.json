						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": \"{{$guid}}\",\n  \"invoices\": [\n    {\n      \"offline_invoice_id\": \"POS-2026-00042\",\n      \"company\": \"{{company}}\",\n      \"customer\": \"{{customer}}\",\n      \"branch\": \"{{branch}}\",\n      \"warehouse\": \"{{warehouse}}\",\n      \"pos_device\": \"{{pos_device}}\",\n      \"cashier\": \"Administrator\",\n      \"shift_id\": \"SHIFT-001\",\n      \"posting_date\": \"2026-06-06\",\n      \"is_pos\": 1,\n      \"submit\": 1,\n      \"items\": [\n        {\n          \"item_code\": \"{{item_code}}\",\n          \"qty\": 2,\n          \"rate\": 100\n        }\n      ],\n      \"payments\": [\n        {\n          \"mode_of_payment\": \"Cash\",\n          \"amount\": 230,\n          \"payment_provider\": \"Cash\"\n        }\n      ],\n      \"promotion_applied\": \"\",\n      \"remarks\": \"Postman test invoice\"\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/method/custom_erpnext.api.v1.push.sync_sales_invoices",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"method",
								"custom_erpnext.api.v1.push.sync_sales_invoices"
							]
						},
						"description": "Create and submit a POS Sales Invoice. Idempotent key: `offline_invoice_id` (unique in ERPNext).\n\n`warehouse` is optional — defaults from Company Branch, then POS Device.\n\n`taxes_and_charges` is optional — defaults from POS Profile, then company default template. Tax rows are applied server-side (required for ZATCA).\n\n**Payment amount** must equal invoice grand total **including VAT** (e.g. 200 + 15% = 230).\n\nResponse includes per-invoice `zatca` payload; poll pull API for async clearance."
					},
					"response": []
				},
				{
					"name": "sync_sales_invoices — Idempotent Retry",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": \"{{$guid}}\",\n  \"invoices\": [\n    {\n      \"offline_invoice_id\": \"POS-2026-00042\"\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/method/custom_erpnext.api.v1.push.sync_sales_invoices",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"method",
								"custom_erpnext.api.v1.push.sync_sales_invoices"
							]
						},
						"description": "Resend only `offline_invoice_id` after a successful submit — returns `idempotent: true` with no duplicate document.\n\nFor a failed draft, resend the full invoice body to re-apply lines before submit retry."
					},
					"response": []
				},
