{
	"info": {
		"_postman_id": "b2c3d4e5-f6a7-48b9-c0d1-e2f3a4b5c6d7",
		"name": "custom_erpnext — Middleware API v2 (Security Hardened)",
		"description": "Updated Postman collection for the custom_erpnext Laravel middleware API, aligned with the P0–P2 security hardening (SEC-01 .. SEC-11).\n\n## What changed vs v1\n\n- **Signing is mandatory.** When the integration is configured with an API secret, every external request MUST be HMAC-signed (SEC-08 fail-closed). `sign_requests` now defaults to `true`.\n- **Canonical signature (SEC-04).** The signed message binds method, path, query, timestamp, request id and body:\n  `METHOD \\n PATH \\n QUERY \\n TIMESTAMP \\n REQUEST_ID \\n BODY`.\n- **`X-Request-ID` is mandatory for signed requests** and is part of the signature.\n- **`full_sync` is POST-only (SEC-09).** A GET is rejected by Frappe with HTTP 403 before the endpoint runs.\n- **Real HTTP status codes.** Error envelopes now return the true status (422 validation, 401 auth, 403 permission, 429 rate limit) — not 200.\n- **Idempotency (SEC-05/06).** Reusing the same `X-Request-ID` on a write replays the original cached response without re-executing side effects (see the `update_pos_device_status` replay pair).\n- **No existence disclosure (SEC-02/SEC-10).** Out-of-scope vs missing records return a uniform error to restricted callers.\n- **Branch-scoped stock push.** Warehouse must be branch-linked; branch and warehouse must match when both are sent.\n- **Branch-scoped device heartbeat.** Device updates require access to the device's branch.\n- **Branch-scoped cashier shift pull.** Omitting `branch` scopes to allowed branches only.\n\n## Quick start\n\n1. Get API credentials:\n   `bench --site YOUR_SITE execute custom_erpnext.setup.laravel_integration.get_middleware_api_credentials`\n2. Import this collection (and optional environment file).\n3. Set collection variables `api_key`, `api_secret`, `base_url`.\n4. Keep `sign_requests = true` (required when the site has a configured secret).\n5. Run with the Collection Runner (folder order matters — push tests chain ids).\n\n## Variables\n\n- base_url: http://tsc.localhost\n- branch: BR1\n- company: tsc\n- pos_device: TEST-POS-BR1\n- item_code: RET-BREAD-WHITE\n- customer: Test Retail Customer\n- cashier: middleware@laravel.local (must have pos_access=1)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://tsc.localhost" },
		{ "key": "api_key", "value": "YOUR_API_KEY" },
		{ "key": "api_secret", "value": "YOUR_API_SECRET" },
		{ "key": "sign_requests", "value": "true" },
		{ "key": "branch", "value": "BR1" },
		{ "key": "company", "value": "tsc" },
		{ "key": "warehouse", "value": "Stores - T" },
		{ "key": "pos_device", "value": "TEST-POS-BR1" },
		{ "key": "item_code", "value": "RET-BREAD-WHITE" },
		{ "key": "customer", "value": "Test Retail Customer" },
		{ "key": "b2b_customer", "value": "ZATCA Sandbox B2B" },
		{ "key": "b2b_customer_address", "value": "ZATCA Sandbox B2B Address-Billing" },
		{ "key": "cashier", "value": "middleware@laravel.local" },
		{ "key": "last_offline_invoice_id", "value": "" },
		{ "key": "last_offline_shift_id", "value": "" },
		{ "key": "movement_suffix", "value": "" },
		{ "key": "last_offline_movement_id", "value": "" },
		{ "key": "other_branch_warehouse", "value": "" },
		{ "key": "other_branch_pos_device", "value": "" },
		{ "key": "pin_request_id", "value": "" },
		{ "key": "current_request_id", "value": "" },
		{ "key": "idem_first_response", "value": "" }
	],
	"auth": { "type": "noauth" },
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const apiKey = pm.collectionVariables.get('api_key');",
					"const apiSecret = pm.collectionVariables.get('api_secret');",
					"const signRequests = pm.collectionVariables.get('sign_requests') === 'true';",
					"",
					"pm.request.headers.upsert({ key: 'Authorization', value: `token ${apiKey}:${apiSecret}` });",
					"pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
					"pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
					"",
					"// X-Request-ID is mandatory for signed requests and is bound to the signature.",
					"const pinned = pm.collectionVariables.get('pin_request_id');",
					"const requestId = (pinned && pinned.length) ? pinned : pm.variables.replaceIn('{{$guid}}');",
					"pm.collectionVariables.set('pin_request_id', '');",
					"pm.collectionVariables.set('current_request_id', requestId);",
					"pm.request.headers.upsert({ key: 'X-Request-ID', value: requestId });",
					"",
					"// Dynamic variables must be set before body resolve + HMAC (request-level",
					"// prerequest runs after this collection script and would otherwise break signing).",
					"(function prepareRequestVariables () {",
					"    const name = pm.info.requestName || '';",
					"    if (name.includes('sync_cashier_movements') && name.includes('Shift Open')) {",
					"        const suffix = pm.variables.replaceIn('{{$guid}}').substring(0, 8);",
					"        pm.collectionVariables.set('last_offline_shift_id', `SHIFT-POSTMAN-${suffix}`);",
					"        pm.collectionVariables.set('movement_suffix', suffix);",
					"    }",
					"    if (name.includes('get_sales_invoice_zatca_status')) {",
					"        const lastId = pm.collectionVariables.get('last_offline_invoice_id');",
					"        if (!lastId) {",
					"            pm.collectionVariables.set('last_offline_invoice_id', 'POS-POSTMAN-SKIP-ZATCA');",
					"        }",
					"    }",
					"})();",
					"",
					"// Resolve variables, then compact JSON so the bytes we sign are identical",
					"// to the bytes Postman sends. Pretty-print / manual edits otherwise cause",
					"// \"Invalid request signature\" even when headers look correct.",
					"let resolvedBody = '';",
					"if (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
					"    resolvedBody = pm.variables.replaceIn(pm.request.body.raw);",
					"    try {",
					"        resolvedBody = JSON.stringify(JSON.parse(resolvedBody));",
					"        pm.request.body.update(resolvedBody);",
					"    } catch (e) {",
					"        // leave non-JSON bodies untouched",
					"    }",
					"}",
					"",
					"if (signRequests && apiSecret && apiSecret !== 'YOUR_API_SECRET') {",
					"    const timestamp = Math.floor(Date.now() / 1000).toString();",
					"    const path = pm.request.url.getPath();",
					"    const query = pm.request.url.getQueryString({ encode: false }) || '';",
					"    const httpMethod = (pm.request.method || 'POST').toUpperCase();",
					"    const message = [httpMethod, path, query, timestamp, requestId, resolvedBody].join('\\n');",
					"    const signature = CryptoJS.HmacSHA256(message, apiSecret).toString(CryptoJS.enc.Hex);",
					"    pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
					"    pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
					"    console.log('[middleware-api] signed', httpMethod, path, 'body_len=' + resolvedBody.length);",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Negative cases set expect_failure=true in their own pre-request script and",
					"// assert their specific status there.",
					"if (pm.variables.get('expect_failure') === 'true') {",
					"    return;",
					"}",
					"pm.test('HTTP status is 200', function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"pm.test('API success=true', function () {",
					"    const json = pm.response.json();",
					"    pm.expect(json).to.have.property('message');",
					"    pm.expect(json.message.success, JSON.stringify(json.message.errors || json)).to.eql(true);",
					"});"
				]
			}
		}
	],
