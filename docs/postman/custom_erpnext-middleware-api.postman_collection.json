						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.request.headers.upsert({ key: 'X-Timestamp', value: Math.floor(Date.now()/1000).toString() });",
									"pm.request.headers.upsert({ key: 'X-Signature', value: 'invalid-signature' });"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP status is 401', () => pm.response.to.have.status(401));",
									"const json = pm.response.json();",
									"pm.test('API success=false', () => pm.expect(json.message.success).to.eql(false));"
								],
								"type": "text/javascript"
							}
						}
