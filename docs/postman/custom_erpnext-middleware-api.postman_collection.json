{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "custom_erpnext — Full Middleware API",
		"description": "Complete Postman collection for **all** custom_erpnext Laravel middleware APIs (Pull + Push).\n\n## Quick start\n\n1. Get API credentials (does **not** rotate secret):\n   bench --site YOUR_SITE execute custom_erpnext.setup.laravel_integration.get_middleware_api_credentials\n2. Import this collection (and optional environment file).\n3. Set collection variables api_key, api_secret, base_url.\n4. Keep sign_requests = false for first run; set true to test HMAC signing.\n5. Run the collection with Collection Runner (folder order matters for push tests).\n\n## Variables\n\n- base_url: http://tsc.localhost\n- branch: BR1\n- company: tsc\n- pos_device: TEST-POS-BR1\n- item_code: RET-BREAD-WHITE\n- customer: Test Retail Customer\n- cashier: middleware@laravel.local (must have pos_access=1)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://tsc.localhost" },
		{ "key": "api_key", "value": "YOUR_API_KEY" },
		{ "key": "api_secret", "value": "YOUR_API_SECRET" },
		{ "key": "sign_requests", "value": "false" },
		{ "key": "branch", "value": "BR1" },
		{ "key": "company", "value": "tsc" },
		{ "key": "warehouse", "value": "Stores - T" },
		{ "key": "pos_device", "value": "TEST-POS-BR1" },
		{ "key": "item_code", "value": "RET-BREAD-WHITE" },
		{ "key": "customer", "value": "Test Retail Customer" },
		{ "key": "b2b_customer", "value": "ZATCA Sandbox B2B" },
		{ "key": "b2b_customer_address", "value": "ZATCA Sandbox B2B Address-Billing" },
		{ "key": "cashier", "value": "middleware@laravel.local" },
		{ "key": "last_offline_invoice_id", "value": "" },
		{ "key": "last_offline_shift_id", "value": "" },
		{ "key": "movement_suffix", "value": "" },
		{ "key": "last_offline_movement_id", "value": "" },
		{ "key": "other_branch_warehouse", "value": "" },
		{ "key": "other_branch_pos_device", "value": "" }
	],
	"auth": { "type": "noauth" },
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const apiKey = pm.collectionVariables.get('api_key');",
					"const apiSecret = pm.collectionVariables.get('api_secret');",
					"const signRequests = pm.collectionVariables.get('sign_requests') === 'true';",
					"",
					"pm.request.headers.upsert({ key: 'Authorization', value: `token ${apiKey}:${apiSecret}` });",
					"pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
					"pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
					"",
					"const requestId = pm.variables.replaceIn('{{$guid}}');",
					"pm.request.headers.upsert({ key: 'X-Request-ID', value: requestId });",
					"",
					"// Dynamic variables must be set before body resolve + HMAC (request-level",
					"// prerequest runs after this collection script and would otherwise break signing).",
					"(function prepareRequestVariables () {",
					"    const name = pm.info.requestName || '';",
					"    if (name.includes('sync_cashier_movements') && name.includes('Shift Open')) {",
					"        const suffix = pm.variables.replaceIn('{{$guid}}').substring(0, 8);",
					"        pm.collectionVariables.set('last_offline_shift_id', `SHIFT-POSTMAN-${suffix}`);",
					"        pm.collectionVariables.set('movement_suffix', suffix);",
					"    }",
					"    if (name.includes('get_sales_invoice_zatca_status')) {",
					"        const lastId = pm.collectionVariables.get('last_offline_invoice_id');",
					"        if (!lastId) {",
					"            pm.collectionVariables.set('last_offline_invoice_id', 'POS-POSTMAN-SKIP-ZATCA');",
					"        }",
					"    }",
					"})();",
					"",
					"let resolvedBody = '';",
					"if (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
					"    resolvedBody = pm.variables.replaceIn(pm.request.body.raw);",
					"    try {",
					"        resolvedBody = JSON.stringify(JSON.parse(resolvedBody));",
					"        pm.request.body.update(resolvedBody);",
					"    } catch (e) {}",
					"}",
					"",
					"if (signRequests && apiSecret && apiSecret !== 'YOUR_API_SECRET') {",
					"    const timestamp = Math.floor(Date.now() / 1000).toString();",
					"    const path = pm.request.url.getPath();",
					"    const query = pm.request.url.getQueryString({ encode: false }) || '';",
					"    const httpMethod = (pm.request.method || 'POST').toUpperCase();",
					"    const message = [httpMethod, path, query, timestamp, requestId, resolvedBody].join('\\n');",
					"    const signature = CryptoJS.HmacSHA256(message, apiSecret).toString(CryptoJS.enc.Hex);",
					"    pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
					"    pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.variables.get('expect_failure') === 'true') {",
					"    return;",
					"}",
					"pm.test('HTTP status is 200', function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"pm.test('API success=true', function () {",
					"    const json = pm.response.json();",
					"    pm.expect(json).to.have.property('message');",
					"  pm.expect(json.message.success, JSON.stringify(json.message.errors || json)).to.eql(true);",
					"});"
				]
			}
		}
	],
