			"name": "02 — Push API (Laravel/POS → ERP)",
			"item": [
				{
					"name": "Sales Invoices",
					"item": [
						{
							"name": "sync_sales_invoices — Create & Submit",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test('HTTP status is 200', () => pm.response.to.have.status(200));",
											"const json = pm.response.json();",
											"pm.test('API success=true', () => pm.expect(json.message.success).to.eql(true));",
											"try {",
											"    const raw = pm.request.body.raw;",
											"    const payload = JSON.parse(raw);",
											"    const offlineId = payload.invoices[0].offline_invoice_id;",
											"    pm.collectionVariables.set('last_offline_invoice_id', offlineId);",
											"} catch (e) {}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"request_id\": \"{{$guid}}\",\n  \"invoices\": [\n    {\n      \"offline_invoice_id\": \"POS-POSTMAN-{{$guid}}\",\n      \"company\": \"{{company}}\",\n      \"customer\": \"{{customer}}\",\n      \"branch\": \"{{branch}}\",\n      \"warehouse\": \"{{warehouse}}\",\n      \"pos_device\": \"{{pos_device}}\",\n      \"cashier\": \"{{cashier}}\",\n      \"shift_id\": \"SHIFT-POSTMAN-001\",\n      \"posting_date\": \"2026-06-27\",\n      \"is_pos\": 1,\n      \"submit\": 1,\n      \"items\": [\n        {\n          \"item_code\": \"{{item_code}}\",\n          \"qty\": 1,\n          \"rate\": 10\n        }\n      ],\n      \"payments\": [\n        {\n          \"mode_of_payment\": \"Cash\",\n          \"amount\": 11.5,\n          \"payment_provider\": \"Cash\"\n        }\n      ],\n      \"remarks\": \"Postman middleware API test\"\n    }\n  ]\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": "{{base_url}}/api/method/custom_erpnext.api.v1.push.sync_sales_invoices",
								"description": "Creates and submits a POS invoice. Payment must include 15% VAT (10 + 1.5 = 11.5). Saves offline_invoice_id for ZATCA poll."
							}
						},
						{
							"name": "sync_sales_invoices — Idempotent Retry",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"request_id\": \"{{$guid}}\",\n  \"invoices\": [\n    {\n      \"offline_invoice_id\": \"{{last_offline_invoice_id}}\"\n    }\n  ]\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": "{{base_url}}/api/method/custom_erpnext.api.v1.push.sync_sales_invoices",
								"description": "Run after Create & Submit. Returns idempotent=true without duplicate."
							}
						},
						{
							"name": "sync_sales_invoices — B2B (with address)",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"request_id\": \"{{$guid}}\",\n  \"invoices\": [\n    {\n      \"offline_invoice_id\": \"POS-B2B-POSTMAN-{{$guid}}\",\n      \"issued_online\": 1,\n      \"company\": \"{{company}}\",\n      \"customer\": \"{{b2b_customer}}\",\n      \"customer_address\": \"{{b2b_customer_address}}\",\n      \"branch\": \"{{branch}}\",\n      \"warehouse\": \"{{warehouse}}\",\n      \"posting_date\": \"2026-06-27\",\n      \"is_pos\": 1,\n      \"submit\": 1,\n      \"taxes_and_charges\": \"VAT 15% - TSC\",\n      \"items\": [\n        {\n          \"item_code\": \"{{item_code}}\",\n          \"qty\": 1,\n          \"rate\": 10\n        }\n      ],\n      \"payments\": [\n        {\n          \"mode_of_payment\": \"Cash\",\n          \"amount\": 11.5,\n          \"payment_provider\": \"Cash\"\n        }\n      ]\n    }\n  ]\n}",
									"options": { "raw": { "language": "json" } }
								},
								"url": "{{base_url}}/api/method/custom_erpnext.api.v1.push.sync_sales_invoices",
								"description": "B2B invoice issued online (SRS §7.3). Requires issued_online: 1 — B2B cannot use the offline queue. Idempotency key is stored as online_invoice_id (offline_invoice_id in the payload is accepted). Requires valid b2b_customer and ZATCA-compliant address."
							}
