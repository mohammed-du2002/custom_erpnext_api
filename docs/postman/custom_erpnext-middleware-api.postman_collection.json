			"name": "03 — Negative / Validation Tests",
			"item": [
				{
					"name": "full_sync — missing branch (expect 422)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP status is 200 (Frappe wraps errors)', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('API success=false', () => pm.expect(json.message.success).to.eql(false));",
									"pm.test('Validation error code', () => {",
									"    const err = (json.message.errors || [])[0] || {};",
									"    pm.expect(err.code || json.message.code).to.eql('VALIDATION_ERROR');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
