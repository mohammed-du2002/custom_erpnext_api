				{
					"name": "sync_cashier_movements — Shift Open/In/Close",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('HTTP status is 200', () => pm.response.to.have.status(200));",
									"const json = pm.response.json();",
									"pm.test('API success=true', () => pm.expect(json.message.success).to.eql(true));",
									"if (json.message.success && json.message.data.results && json.message.data.results[0]) {",
									"    pm.collectionVariables.set('last_offline_movement_id', json.message.data.results[0].offline_movement_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
